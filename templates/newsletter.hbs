<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if frontMatter.title}}{{frontMatter.title}}{{else}}Newsletter{{/if}}</title>
  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      line-height: 1.65;
      color: #1a1a1a;
      max-width: 600px;
      margin: 0 auto;
      padding: 0;
      background: #f9f9f9;
    }
    .container {
      background: #ffffff;
      padding: 40px 50px;
      margin: 20px 0;
      border-radius: 8px;
    }
    .header {
      text-align: center;
      padding-bottom: 30px;
      border-bottom: 1px solid #eee;
      margin-bottom: 30px;
    }
    .header h1 {
      font-size: 1.75rem;
      margin: 0 0 8px 0;
      color: #111;
    }
    .header .date {
      font-size: 0.85rem;
      color: #888;
    }
    .content h2 {
      font-size: 1.35rem;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: #111;
    }
    .content h3 {
      font-size: 1.1rem;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .content p {
      margin-bottom: 1rem;
      color: #333;
    }
    .content a {
      color: #0066cc;
      text-decoration: underline;
    }
    .content code {
      background: #f0f0f0;
      padding: 0.15em 0.4em;
      border-radius: 3px;
      font-size: 0.9em;
      font-family: 'SF Mono', Monaco, monospace;
    }
    .content pre {
      background: #f5f5f5;
      padding: 1rem;
      border-radius: 6px;
      overflow-x: auto;
      font-size: 0.85rem;
      line-height: 1.5;
    }
    .content pre code { background: none; padding: 0; }
    .content blockquote {
      border-left: 3px solid #0066cc;
      margin: 1.25rem 0;
      padding: 0.25rem 0 0.25rem 1rem;
      color: #555;
      font-style: italic;
    }
    .content ul, .content ol {
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .content li { margin-bottom: 0.5rem; }
    .highlight {
      background: #fff3cd;
      padding: 15px 20px;
      border-radius: 6px;
      margin: 1.25rem 0;
    }
    .footer {
      text-align: center;
      padding-top: 30px;
      margin-top: 40px;
      border-top: 1px solid #eee;
      font-size: 0.85rem;
      color: #888;
    }
    @media print {
      body { background: #fff; }
      .container { box-shadow: none; margin: 0; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{#if frontMatter.title}}{{frontMatter.title}}{{else}}Newsletter{{/if}}</h1>
      <div class="date">{{#if frontMatter.date}}{{frontMatter.date}}{{else}}{{currentDate}}{{/if}}</div>
    </div>
    <div class="content">
      {{{content}}}
    </div>
    <div class="footer">
      Generated with md2pdf2
    </div>
  </div>
</body>
</html>
